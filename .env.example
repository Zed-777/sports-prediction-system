# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# ================================
# DATA SOURCE API KEYS
# ================================

# Football Data Sources
FOOTBALL_DATA_API_KEY=your_football_data_org_api_key_here
API_FOOTBALL_KEY=your_api_football_com_key_here
# API-Football (via RapidAPI) provides player injury/availability endpoints.
# Sign up at https://rapidapi.com/api-sports/api/api-football and paste your
# X-RapidAPI-Key here. When set, the system will attempt to fetch injuries and
# suspensions and include them in the player availability section of reports.

NEWSAPI_KEY=your_newsapi_key_here
# (Optional) NewsAPI key to fetch team news for lineup/injury mentions.
# When set, the system will query recent articles to extract lineup and injury
# mentions and include them in the team news analysis.

# Basketball Data Sources  
BALLDONTLIE_API_KEY=your_balldontlie_api_key_here
SPORTSDATA_API_KEY=your_sportsdata_io_api_key_here

# General Sports Data
SPORTSRADAR_API_KEY=your_sportsradar_api_key_here
ODDS_API_KEY=your_the_odds_api_key_here

# Weather Data (optional)
OPENMETEO_API_KEY=your_open_meteo_key_here

# ================================
# DATABASE CONFIGURATION
# ================================

# For PostgreSQL (production)
DATABASE_URL=postgresql://username:password@localhost:5432/sports_predictions
POSTGRES_PASSWORD=your_secure_postgres_password

# ================================
# MONITORING & ALERTS
# ================================

# Slack notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Email notifications (optional)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# ================================
# APPLICATION SETTINGS
# ================================

# Environment (dev, staging, prod)
ENVIRONMENT=dev

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# MLflow tracking (optional)
MLFLOW_TRACKING_URI=http://localhost:5000

# ================================
# SECURITY SETTINGS
# ================================

# Secret key for web dashboard sessions
SECRET_KEY=your_very_secure_secret_key_here

# JWT secret for API authentication (if enabled)
JWT_SECRET=your_jwt_secret_key_here

# ================================
# RATE LIMITING
# ================================

# API request delays (milliseconds)
API_REQUEST_DELAY=1000
MAX_REQUESTS_PER_MINUTE=60

# ================================
# CACHE SETTINGS
# ================================

# Redis URL for caching (optional)
REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds
CACHE_TTL=3600

# ================================
# EXTERNAL SERVICES
# ================================

# OpenTelemetry endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Sentry DSN for error tracking (optional)
SENTRY_DSN=https://your_sentry_dsn_here

# ================================
# DEVELOPMENT SETTINGS
# ================================

# Enable debug mode (dev only)
DEBUG=true

# Enable hot reload for dashboard
HOT_RELOAD=true

# Skip SSL verification (dev only - never use in production)
SKIP_SSL_VERIFY=false